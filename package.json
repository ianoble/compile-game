{
	"name": "compile-game",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/ianoble/compile-game.git"
	},
	"scripts": {
		"dev": "vite",
		"build:engine": "npx tsc --project noble-bg-engine/packages/engine/tsconfig.json",
		"build": "vite build",
		"preview": "vite preview",
		"lint": "eslint . --report-unused-disable-directives --max-warnings 0",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"type-check": "vue-tsc --noEmit --skipLibCheck",
		"check": "npm run format:check && npm run lint && npm run type-check",
		"audit-abilities": "node scripts/audit-abilities.js"
	},
	"dependencies": {
		"@noble/bg-engine": "file:noble-bg-engine/packages/engine",
		"@tabler/icons-vue": "^3.38.0",
		"boardgame.io": "^0.50.2",
		"pinia": "^2.3.0",
		"vue": "^3.5.0",
		"vue-router": "^4.5.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tailwindcss/vite": "^4.0.0",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"@vitejs/plugin-vue": "^5.0.0",
		"@vue/eslint-config-typescript": "^14.7.0",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-vue": "^10.8.0",
		"prettier": "^3.8.1",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.7.0",
		"vite": "^5.0.0",
		"vue-tsc": "^2.0.0"
	}
}
